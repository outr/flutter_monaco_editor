# OS
.DS_Store
Thumbs.db

# Platform scaffolding is tracked so our customizations (AndroidManifest
# INTERNET permission, Linux my_application.cc GtkOverlay wrapper, iOS
# NSAppTransportSecurity for localhost, etc.) survive a re-`flutter create`.
# Ignore just the generated build artifacts within them.
example/*/build/
example/*/.gradle/
example/*/Pods/
example/android/.gradle/
example/android/app/build/
example/android/build/
example/ios/Pods/
example/linux/flutter/ephemeral/
example/macos/Pods/
example/windows/flutter/ephemeral/
example/*/.idea/

# Scratch
/tmp/
*.log
.flutter-plugins-dependencies
.claude/
